# Google Gemini API key (get one from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_key_here

# Text model that drives the branching narrative + structured choices
TEXT_MODEL=gemini-2.5-flash

# Image model. Set this to the hackathon's Nano Banana 2 Lite model ID.
# Falls back to a public image model so the app runs before you have NB2 Lite access.
IMAGE_MODEL=gemini-2.5-flash-image

# NPC voice (Gemini TTS / Live API voice model)
VOICE_MODEL=gemini-2.5-flash-preview-tts
